# Docker Hub Username for pulling images
DOCKER_USERNAME=your_dockerhub_username

# Database Configuration
# POSTGRES_PASSWORD is used by the local-db profile if you run it
POSTGRES_PASSWORD=changeme

# DATABASE_URL is used by the backend to connect (to local or external DB)
# For local DB: postgresql://vaultmgr:changeme@postgres:5432/vaultmanager
# For external DB: postgresql://user:password@external-host:5432/dbname
DATABASE_URL=postgresql://vaultmgr:changeme@postgres:5432/vaultmanager

# Security - Change these for production!
SECRET_KEY=development_secret_key_change_in_production
ENCRYPTION_KEY=change_this_to_a_valid_fernet_key
